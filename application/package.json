{
  "name": "@web-speed-hackathon-2026/application",
  "private": true,
  "license": "MPL-2.0",
  "author": "CyberAgent, Inc.",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @web-speed-hackathon-2026/client build",
    "dev": "pnpm --filter @web-speed-hackathon-2026/server dev & pnpm --filter @web-speed-hackathon-2026/client dev",
    "start": "pnpm --filter @web-speed-hackathon-2026/server start",
    "typecheck": "pnpm run --recursive typecheck",
    "e2e": "pnpm build && pnpm --filter @web-speed-hackathon-2026/server e2e:start & sleep 3 && E2E_BASE_URL=http://localhost:3010 pnpm --filter @web-speed-hackathon-2026/e2e test; kill %1 2>/dev/null",
    "format": "pnpm run format:oxlint && pnpm run format:oxfmt",
    "format:oxlint": "oxlint --fix",
    "format:oxfmt": "oxfmt"
  },
  "devDependencies": {
    "@rsdoctor/rspack-plugin": "1.5.5",
    "oxfmt": "0.36.0",
    "oxlint": "1.43.0"
  },
  "engines": {
    "node": "24.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ffmpeg-static"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
